{
  "name": "frieren-desktop",
  "version": "0.3.0",
  "description": "Real-time Electron desktop client for the Frieren AI ecosystem.",
  "private": true,
  "type": "module",
  "main": "electron/main.js",
  "author": "Frierenclaw",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Frierenclaw/frieren-desktop.git"
  },
  "bugs": {
    "url": "https://github.com/Frierenclaw/frieren-desktop/issues"
  },
  "homepage": "https://github.com/Frierenclaw/frieren-desktop#readme",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:1420 && electron .\"",
    "build": "vite build",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "@pixiv/three-vrm": "^3.1.0",
    "@pixiv/three-vrm-animation": "^3.5.3",
    "electron-store": "^10.0.0",
    "livekit-client": "^2.5.0",
    "three": "^0.170.0"
  },
  "devDependencies": {
    "concurrently": "^9.0.0",
    "electron": "^33.4.11",
    "electron-builder": "^25.0.0",
    "vite": "^8.0.16",
    "wait-on": "^8.0.0"
  },
  "build": {
    "appId": "ai.frieren.desktop",
    "productName": "frieren-desktop",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "publish": {
      "provider": "github",
      "owner": "Frierenclaw",
      "repo": "frieren-desktop",
      "releaseType": "release"
    },
    "mac": {
      "icon": "icons/icon.icns",
      "category": "public.app-category.utilities"
    },
    "win": {
      "icon": "icons/icon.ico"
    },
    "linux": {
      "icon": "icons/icon.png",
      "target": [
        "AppImage"
      ]
    }
  }
}
